# ============================================================
# ASA Migration Parser - Crypto Remediation Report
# ============================================================
# PURPOSE:
#   Generates a per-tunnel, per-peer crypto remediation report
#   from parsed Phase 4 crypto data. Identifies every crypto
#   map entry that references a REMOVED or DEPRECATED algorithm,
#   maps it to its peer IP(s) and match ACL, and provides an
#   explicit FMC-compatible replacement recommendation.
#
#   This is the actionable artifact for updating staged S2S VPN
#   configurations in FMC before cutover. The technical report
#   flags algorithm status; this report tells you exactly what
#   to change and what to change it to.
#
# USAGE — STANDALONE:
#   python asa_crypto_remediation.py <path_to_log_file>
#   Example: python asa_crypto_remediation.py asa_logs.txt
#
# USAGE — FROM PHASE 6:
#   from asa_crypto_remediation import build_remediation_report
#   report = build_remediation_report(results)
#   write_report(report, remediation_path)
#
# OUTPUT:
#   asa_migration_crypto_remediation.txt
#   Written to the same directory as the log file.
#
# INPUT DEPENDENCIES (from parse_crypto / run_all_parsers):
#   ikev1_ts          — IKEv1 transform sets with FTD status
#   ikev2_proposals   — IKEv2 IPsec proposals with algorithms
#   ikev1_policies    — IKEv1 Phase 1 policies with FTD status
#   ikev2_policies    — IKEv2 Phase 1 policies
#   crypto_maps       — Static crypto map entries (peer, TS, ACL)
#   map_interfaces    — Crypto map to interface binding
#
# ALGORITHM REPLACEMENT LOGIC:
#   REMOVED encryption  (DES, 3DES)     → AES-256
#   REMOVED integrity   (MD5)           → SHA-256
#   REMOVED DH group    (1, 2, 24)      → Group 14 (minimum)
#   DEPRECATED integrity (SHA-1/SHA)    → SHA-256 (recommended)
#   DEPRECATED DH group (5)             → Group 14 (minimum)
#   All replacements are Cisco-documented, FMC 7.2.x compatible.
#
# REPORT STRUCTURE:
#   Section 1 — Summary: counts by status, affected tunnel count
#   Section 2 — Transform Set Remediation: per-TS action table
#   Section 3 — IKEv2 Proposal Remediation: per-proposal table
#   Section 4 — IKEv1 Phase 1 Remediation: per-policy table
#   Section 5 — Per-Tunnel Action Table: crypto map → peer → fix
#   Section 6 — FMC Update Checklist: ordered action items
#   Section 7 — Unaffected Tunnels: confirmation of clean entries
# ============================================================

import re
import sys
import os
from datetime import datetime
from collections import defaultdict


# ════════════════════════════════════════════════════════════
# SECTION HEADER PATTERN (shared with p4/p6)
# ════════════════════════════════════════════════════════════

SECTION_PATTERN = re.compile(
    r'^!\s*===SECTION:\s*([A-Z0-9_\-]+)\s*===$',
    re.IGNORECASE
)


# ════════════════════════════════════════════════════════════
# REPLACEMENT RECOMMENDATION TABLES
# Source: Cisco FMC Configuration Guide 7.2 / 7.6
#         NIST SP 800-131A Rev 2 (algorithm deprecation)
#
# Logic:
#   REMOVED algs → Minimum required replacement for FTD 6.7+
#   DEPRECATED   → Recommended upgrade (not blocking today on
#                  FMC 7.2.x but will fail on future versions)
# ════════════════════════════════════════════════════════════

ESP_ENC_REPLACEMENT = {
    'esp-des'  : 'esp-aes-256',
    'esp-3des' : 'esp-aes-256',
    'des'      : 'aes-256',
    '3des'     : 'aes-256',
}

ESP_INT_REPLACEMENT = {
    'esp-md5-hmac' : 'esp-sha256-hmac',
    'esp-sha-hmac' : 'esp-sha256-hmac',
    'md5'          : 'sha256',
    'sha'          : 'sha256',
    'sha-1'        : 'sha256',
    'md5-96'       : 'sha256',
}

IKE_ENC_REPLACEMENT = {
    'des'  : 'aes-256',
    '3des' : 'aes-256',
}

IKE_HASH_REPLACEMENT = {
    'md5'   : 'sha256',
    'sha'   : 'sha256',
    'sha-1' : 'sha256',
}

DH_GROUP_REPLACEMENT = {
    '1'  : '14',
    '2'  : '14',
    '5'  : '14',
    '24' : '20',
}


# ════════════════════════════════════════════════════════════
# REPLACEMENT LOOKUP HELPERS
# ════════════════════════════════════════════════════════════

def get_esp_enc_replacement(alg):
    return ESP_ENC_REPLACEMENT.get(alg.lower().strip())

def get_esp_int_replacement(alg):
    if not alg:
        return None
    return ESP_INT_REPLACEMENT.get(alg.lower().strip())

def get_ike_enc_replacement(alg):
    return IKE_ENC_REPLACEMENT.get(alg.lower().strip())

def get_ike_hash_replacement(alg):
    return IKE_HASH_REPLACEMENT.get(alg.lower().strip())

def get_dh_replacement(group):
    g = re.sub(r'group\s*', '', str(group).lower()).strip()
    return DH_GROUP_REPLACEMENT.get(g)

def needs_action(status):
    return status in ('REMOVED', 'DEPRECATED')


# ════════════════════════════════════════════════════════════
# FTD STATUS LOOKUPS (inline — avoids importing p4)
# These mirror the FTD_* tables in asa_parser_p4.py exactly.
# ════════════════════════════════════════════════════════════

_FTD_ESP_ENCRYPTION = {
    'esp-des': 'REMOVED', 'esp-3des': 'REMOVED',
    'esp-aes': 'OK', 'esp-aes-192': 'OK', 'esp-aes-256': 'OK',
    'esp-aes-gcm': 'OK', 'esp-aes-gcm-192': 'OK',
    'esp-aes-gcm-256': 'OK', 'esp-null': 'OK',
    'des': 'REMOVED', '3des': 'REMOVED',
    'aes': 'OK', 'aes-192': 'OK', 'aes-256': 'OK',
    'aes-gcm': 'OK', 'aes-gcm-192': 'OK', 'aes-gcm-256': 'OK',
    'null': 'OK',
}
_FTD_ESP_INTEGRITY = {
    'esp-md5-hmac': 'REMOVED', 'esp-sha-hmac': 'DEPRECATED',
    'esp-sha256-hmac': 'OK', 'esp-sha384-hmac': 'OK',
    'esp-sha512-hmac': 'OK', 'esp-none': 'OK',
    'md5': 'REMOVED', 'sha': 'DEPRECATED', 'sha256': 'OK',
    'sha384': 'OK', 'sha512': 'OK', 'null': 'OK', 'none': 'OK',
    'sha-1': 'DEPRECATED', 'sha-256': 'OK',
    'sha-384': 'OK', 'sha-512': 'OK', 'md5-96': 'REMOVED',
}
_FTD_IKE_ENCRYPTION = {
    'des': 'REMOVED', '3des': 'REMOVED',
    'aes': 'OK', 'aes-192': 'OK', 'aes-256': 'OK',
    'aes-gcm': 'OK', 'aes-gcm-192': 'OK', 'aes-gcm-256': 'OK',
    'null': 'OK',
}
_FTD_IKE_HASH = {
    'md5': 'REMOVED', 'sha': 'DEPRECATED', 'sha256': 'OK',
    'sha384': 'OK', 'sha512': 'OK',
    'sha-1': 'DEPRECATED', 'sha-256': 'OK',
    'sha-384': 'OK', 'sha-512': 'OK',
    'null': 'OK', 'none': 'OK',
}
_FTD_DH_GROUPS = {
    '1': 'REMOVED', '2': 'REMOVED', '5': 'DEPRECATED',
    '14': 'OK', '19': 'OK', '20': 'OK', '21': 'OK', '24': 'REMOVED',
}


def _ftd_esp_enc_status(alg):
    return _FTD_ESP_ENCRYPTION.get(alg.lower().strip(), 'UNKNOWN')

def _ftd_esp_int_status(alg):
    return _FTD_ESP_INTEGRITY.get(alg.lower().strip(), 'UNKNOWN')

def _ftd_ike_enc_status(alg):
    if not alg:
        return 'UNKNOWN'
    return _FTD_IKE_ENCRYPTION.get(alg.lower().strip(), 'UNKNOWN')

def _ftd_ike_hash_status(alg):
    if not alg:
        return 'UNKNOWN'
    return _FTD_IKE_HASH.get(alg.lower().strip(), 'UNKNOWN')

def _ftd_dh_status(group):
    if not group:
        return 'UNKNOWN'
    g = re.sub(r'group\s*', '', str(group).lower()).strip()
    return _FTD_DH_GROUPS.get(g, 'UNKNOWN')

def _short_status(status):
    return {
        'REMOVED'    : '[REMOVED]',
        'DEPRECATED' : '[DEPRECATED]',
        'OK'         : '[OK]',
        'UNKNOWN'    : '[UNKNOWN]',
        'N/A'        : '[N/A]',
    }.get(status, '[UNKNOWN]')


