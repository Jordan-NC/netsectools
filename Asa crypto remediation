# CORE REPORT BUILDER (public API — called by p6)
# ════════════════════════════════════════════════════════════

def build_remediation_report(results, hostname='(unknown)'):
    """
    Builds the full crypto remediation report from parsed results.

    Args:
        results  : dict from run_all_parsers() — requires keys:
                   ikev1_ts, ikev2_proposals, ikev1_policies,
                   ikev2_policies, crypto_maps, map_interfaces
        hostname : ASA hostname string for report header

    Returns:
        Complete report as a single string.
    """
    out = []
    now = datetime.now().strftime("%Y-%m-%d %H:%M")

    ikev1_ts        = results.get('ikev1_ts', [])
    ikev2_proposals = results.get('ikev2_proposals', [])
    ikev1_policies  = results.get('ikev1_policies', [])
    ikev2_policies  = results.get('ikev2_policies', [])
    crypto_maps     = results.get('crypto_maps', {})
    map_interfaces  = results.get('map_interfaces', {})

    # ── Report header ─────────────────────────────────────────
    out.append("=" * 78)
    out.append("  CISCO ASA TO FTD — CRYPTO REMEDIATION REPORT")
    out.append("=" * 78)
    out.append("  Device      : " + hostname)
    out.append("  Target FMC  : 7.2.8  (also valid for 7.6.x)")
    out.append("  Report Date : " + now)
    out.append("=" * 78)
    out.append("")
    out.append("  PURPOSE")
    out.append("  " + "-" * 74)
    out.append(
        "  This report identifies every VPN tunnel configuration that\n"
        "  references a REMOVED or DEPRECATED cryptographic algorithm\n"
        "  and provides an explicit FMC-compatible replacement for each.\n"
        "\n"
        "  REMOVED algorithms will cause FMC deployment failures.\n"
        "  Tunnels using these algorithms cannot be deployed until fixed.\n"
        "\n"
        "  DEPRECATED algorithms are currently functional on FMC 7.2.x\n"
        "  and 7.6.x but flagged by Cisco for future removal. Update\n"
        "  as part of this migration cleanup.\n"
        "\n"
        "  Use Section 5 (Per-Tunnel Action Table) as your working\n"
        "  reference when updating VPN configurations in FMC.\n"
        "  Use Section 6 (FMC Update Checklist) to drive the updates."
    )
    out.append("")

    # ── Pre-compute affected sets ─────────────────────────────
    affected_ts_names = {
        ts['name'] for ts in ikev1_ts
        if needs_action(ts['ftd_enc']) or
           (needs_action(ts['ftd_hash']) and ts['ftd_hash'] != 'N/A')
    }
    removed_ts_names = {
        ts['name'] for ts in ikev1_ts
        if ts['ftd_enc'] == 'REMOVED' or ts['ftd_hash'] == 'REMOVED'
    }

    affected_prop_names = set()
    removed_prop_names  = set()
    for prop in ikev2_proposals:
        enc_issues = [
            a for a in prop['encryption']
            if needs_action(_ftd_esp_enc_status(a))
        ]
        int_issues = [
            a for a in prop['integrity']
            if needs_action(_ftd_esp_int_status(a))
        ]
        if enc_issues or int_issues:
            affected_prop_names.add(prop['name'])
        if any(_ftd_esp_enc_status(a) == 'REMOVED' for a in prop['encryption']) or \
           any(_ftd_esp_int_status(a) == 'REMOVED' for a in prop['integrity']):
            removed_prop_names.add(prop['name'])

    affected_ikev1_priorities = []
    for pol in ikev1_policies:
        enc_sts  = _ftd_ike_enc_status(pol.get('encryption', ''))
        hash_sts = _ftd_ike_hash_status(pol.get('hash', ''))
        grp_sts  = _ftd_dh_status(pol.get('group', ''))
        if needs_action(enc_sts) or needs_action(hash_sts) or needs_action(grp_sts):
            affected_ikev1_priorities.append(pol['priority'])

    affected_tunnel_entries = _get_affected_tunnel_entries(
        crypto_maps, affected_ts_names, affected_prop_names,
        affected_ikev1_priorities
    )

    # ── Sections ──────────────────────────────────────────────
    out.append(_section_hdr("1", "SUMMARY"))
    out.extend(_build_summary(
        ikev1_ts, ikev2_proposals, ikev1_policies, ikev2_policies,
        crypto_maps, affected_ts_names, removed_ts_names,
        affected_prop_names, removed_prop_names,
        affected_ikev1_priorities, affected_tunnel_entries
    ))

    out.append(_section_hdr("2", "IKEV1 TRANSFORM SET REMEDIATION"))
    out.extend(_build_ts_remediation(ikev1_ts))

    out.append(_section_hdr("3", "IKEV2 IPSEC PROPOSAL REMEDIATION"))
    out.extend(_build_prop_remediation(ikev2_proposals))

    out.append(_section_hdr("4", "IKEV1 PHASE 1 POLICY REMEDIATION"))
    out.extend(_build_ikev1_policy_remediation(ikev1_policies))

    out.append(_section_hdr("5", "PER-TUNNEL ACTION TABLE"))
    out.extend(_build_per_tunnel_table(
        crypto_maps, map_interfaces,
        ikev1_ts, ikev2_proposals,
        affected_ts_names, affected_prop_names
    ))

    out.append(_section_hdr("6", "FMC UPDATE CHECKLIST"))
    out.extend(_build_fmc_checklist(
        ikev1_ts, ikev2_proposals, ikev1_policies,
        affected_ts_names, affected_prop_names,
        affected_ikev1_priorities, affected_tunnel_entries
    ))

    out.append(_section_hdr("7", "UNAFFECTED TUNNELS (NO ACTION REQUIRED)"))
    out.extend(_build_clean_tunnels(
        crypto_maps, map_interfaces,
        affected_ts_names, affected_prop_names
    ))

    # ── Footer ────────────────────────────────────────────────
    out.append("")
    out.append("=" * 78)
    out.append("  END OF CRYPTO REMEDIATION REPORT")
    out.append("  Generated by ASA Migration Parser — Crypto Remediation Module")
    out.append("  " + now)
    out.append("=" * 78)

    return "\n".join(out)


# ════════════════════════════════════════════════════════════
# STANDALONE MAIN
# ════════════════════════════════════════════════════════════

def main():
    if len(sys.argv) != 2:
        print("Usage: python asa_crypto_remediation.py <path_to_log_file>")
        print("Example: python asa_crypto_remediation.py asa_logs.txt")
        sys.exit(1)

    filepath = sys.argv[1]

    if not os.path.isfile(filepath):
        print(f"[ERROR] File not found: {filepath}")
        sys.exit(1)

    if os.path.getsize(filepath) == 0:
        print(f"[ERROR] File is empty: {filepath}")
        sys.exit(1)

    script_dir = os.path.dirname(os.path.abspath(__file__))
    if script_dir not in sys.path:
        sys.path.insert(0, script_dir)

    p4_path = os.path.join(script_dir, 'asa_parser_p4.py')
    if not os.path.isfile(p4_path):
        print("[ERROR] asa_parser_p4.py not found in the same directory.")
        print("        This module is required to parse the crypto section.")
        sys.exit(1)

    import asa_parser_p4 as p4

    print()
    print("=" * 60)
    print("  ASA MIGRATION PARSER — CRYPTO REMEDIATION REPORT")
    print("=" * 60)

    print("\n  [1/3] Extracting sections from log file...")
    sections_data = p4.extract_sections(filepath)
    print(f"        {len(sections_data)} section(s) found")

    print("  [2/3] Parsing crypto configuration...")
    crypto_lines = sections_data.get("RUNNING-CONFIG-CRYPTO", [])
    if not crypto_lines:
        print("  [ERROR] RUNNING-CONFIG-CRYPTO section not found.")
        print("          Verify your log file contains:")
        print("          ! ===SECTION: RUNNING-CONFIG-CRYPTO===")
        sys.exit(1)

    crypto_results = p4.parse_crypto(crypto_lines)
    (
        ikev1_policies, ikev2_policies,
        ikev1_ts, ikev2_proposals,
        ipsec_profiles, dynamic_maps,
        crypto_maps, ike_enables,
        map_interfaces, isakmp_globals,
        ipsec_globals, sa_settings,
        pki_trustpoints, pki_cert_chains,
        pki_ra_trustpoint, pki_trustpool,
        ikev1_am_disable, partials, unmatched,
    ) = crypto_results

    results = {
        'ikev1_policies'   : ikev1_policies,
        'ikev2_policies'   : ikev2_policies,
        'ikev1_ts'         : ikev1_ts,
        'ikev2_proposals'  : ikev2_proposals,
        'ipsec_profiles'   : ipsec_profiles,
        'dynamic_maps'     : dynamic_maps,
        'crypto_maps'      : crypto_maps,
        'ike_enables'      : ike_enables,
        'map_interfaces'   : map_interfaces,
        'isakmp_globals'   : isakmp_globals,
        'ipsec_globals'    : ipsec_globals,
        'sa_settings'      : sa_settings,
        'pki_trustpoints'  : pki_trustpoints,
        'pki_cert_chains'  : pki_cert_chains,
        'pki_ra_trustpoint': pki_ra_trustpoint,
        'pki_trustpool'    : pki_trustpool,
        'ikev1_am_disable' : ikev1_am_disable,
        'crypto_partials'  : partials,
        'crypto_unmatched' : unmatched,
    }

    hostname = '(unknown)'
    for section in ['VERSION', 'RUNNING-CONFIG-ALL', 'RUNNING-CONFIG']:
        for line in sections_data.get(section, [])[:50]:
            m = re.match(r'^hostname\s+(\S+)', line.strip(), re.IGNORECASE)
            if m:
                hostname = m.group(1)
                break
        if hostname != '(unknown)':
            break

    print(f"        Transform sets  : {len(ikev1_ts)}")
    print(f"        IKEv2 proposals : {len(ikev2_proposals)}")
    print(f"        IKEv1 policies  : {len(ikev1_policies)}")
    print(f"        Crypto map entries: {sum(len(v) for v in crypto_maps.values())}")

    print("  [3/3] Building remediation report...")
    report = build_remediation_report(results, hostname)

    log_dir  = os.path.dirname(os.path.abspath(filepath))
    out_path = os.path.join(log_dir, "asa_migration_crypto_remediation.txt")

    with open(out_path, 'w', encoding='utf-8') as f:
        f.write(report)

    print(f"        Output : {out_path}")
    print()
    print("=" * 60)
    print("  COMPLETE")
    print("=" * 60)
    print()
    print("  Review Section 1 for summary counts.")
    print("  Use Section 5 as your per-tunnel working reference.")
    print("  Follow Section 6 checklist when updating FMC.")
    print()


if __name__ == "__main__":
    main()
